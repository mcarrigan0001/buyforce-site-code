{
  "manifest_version": 3,
  "name": "BuyForce Inbox Overlay",
  "version": "0.1.0",
  "description": "Decorates the Facebook Marketplace Buying inbox with each deal's BuyForce pipeline data (stage, time-in-stage, next action). Read-only.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://buyforce.app.n8n.cloud/*",
    "https://www.facebook.com/*",
    "https://web.facebook.com/*",
    "https://buyforce.noloco.co/*"
  ],
  "background": { "service_worker": "src/background.js" },
  "content_scripts": [
    {
      "matches": ["https://www.facebook.com/*", "https://web.facebook.com/*"],
      "js": ["src/config.js", "src/match.js", "src/content.js"],
      "css": ["src/badges.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://buyforce.noloco.co/*"],
      "js": ["src/token-bridge.js"],
      "run_at": "document_idle"
    }
  ]
}
