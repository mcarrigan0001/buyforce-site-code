{
  "manifest_version": 3,
  "name": "BuyForce Inbox Overlay",
  "version": "0.2.0",
  "description": "BuyForce sidebar for Facebook Marketplace: capture listings as leads, badge inbox conversations, and surface each deal's pipeline data (stage, time-in-stage, next action). Assist-only.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://buyforce.app.n8n.cloud/*",
    "https://www.facebook.com/*",
    "https://web.facebook.com/*",
    "https://buyforce.noloco.co/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.facebook.com/*",
        "https://web.facebook.com/*"
      ],
      "js": [
        "src/config.js",
        "src/match.js",
        "src/sidebar.js",
        "src/content.js",
        "src/listing.js"
      ],
      "css": [
        "src/badges.css",
        "src/capture.css",
        "src/sidebar.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://buyforce.noloco.co/*"
      ],
      "js": [
        "src/token-bridge.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
