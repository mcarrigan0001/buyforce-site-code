{
  "manifest_version": 3,
  "name": "BuyForce Inbox Overlay",
  "version": "0.2.0",
  "description": "BuyForce sidebar for Facebook Marketplace: capture listings as leads, badge inbox conversations, and surface each deal's pipeline data (stage, time-in-stage, next action). Also a CarMax/Carvana window-sticker helper that highlights which options a vehicle has. Assist-only.",
  "permissions": [
    "storage",
    "offscreen"
  ],
  "host_permissions": [
    "https://buyforce.app.n8n.cloud/*",
    "https://vpic.nhtsa.dot.gov/*",
    "https://www.facebook.com/*",
    "https://web.facebook.com/*",
    "https://buyforce.noloco.co/*",
    "https://*.carvana.com/*",
    "https://*.carmax.com/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.facebook.com/*",
        "https://web.facebook.com/*"
      ],
      "js": [
        "src/config.js",
        "src/match.js",
        "src/sidebar.js",
        "src/content.js",
        "src/listing.js"
      ],
      "css": [
        "src/badges.css",
        "src/capture.css",
        "src/sidebar.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://*.carvana.com/*",
        "https://*.carmax.com/*"
      ],
      "js": [
        "src/sticker-match.js",
        "src/sticker.js"
      ],
      "css": [
        "src/sticker.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://buyforce.noloco.co/*"
      ],
      "js": [
        "src/token-bridge.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}
